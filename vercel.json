{
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/api/park-weather", "destination": "/api/park-weather.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "mlb-tracker-grandsalami.vercel.app"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-gs-scraper",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron-outcomes",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron-resolve-yesterday",
      "schedule": "15 9 * * *"
    },
    {
      "path": "/api/cron-alt-lines",
      "schedule": "0 10 * * *"
    }
  ]
}
